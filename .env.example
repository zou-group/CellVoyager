# OpenAI API Key (required for hypothesis generation and legacy execution mode)
# For MiniMax models, set this to your MiniMax API key
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# Anthropic API Key (required for claude execution mode)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Optional: Custom Base URL for OpenAI-compatible APIs
# For MiniMax models, uncomment and set to use MiniMax-M2.7-highspeed or other MiniMax models
OPENAI_BASE_URL=https://api.minimaxi.com/v1

# When using MiniMax:
# 1. Set OPENAI_API_KEY to your MiniMax API key (from https://platform.minimaxi.com/)
# 2. Set OPENAI_BASE_URL to https://api.minimaxi.com/v1
# 3. Use --model-name "MiniMax-M2.7-highspeed" when running
# Example configuration for MiniMax:
# OPENAI_API_KEY=your_minimax_api_key_here
# OPENAI_BASE_URL=https://api.minimaxi.com/v1
